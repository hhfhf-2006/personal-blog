
# 后端服务端口
SERVER_PORT=8080

# PostgreSQL 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=blog
DB_PASSWORD=your_database_password
DB_NAME=blog_db
DB_SSLMODE=disable

# JWT 令牌签名密钥（生产环境请换成随机字符串！）
JWT_SECRET=your_random_secret_here

# 管理员账号配置
# - 邮箱注册时匹配 ADMIN_EMAIL 自动获得管理员权限
# - GitHub 用户名为 hhfhf-2006 的用户自动映射为管理员（硬编码，不可修改）
ADMIN_EMAIL=your_admin_email@example.com
ADMIN_USERNAME=管理员
ADMIN_PASSWORD=your_admin_password

# GitHub OAuth 配置
# 1. 在 GitHub Settings → Developer settings → OAuth Apps 创建应用
# 2. 将获得的 Client ID 和 Client Secret 填入下方
# 3. Authorization callback URL 设置为: http://localhost:8080/api/v1/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8080/api/v1/auth/github/callback

# HTTP 代理（国内环境访问 GitHub API 可能需要）
# 例如: HTTP_PROXY=http://127.0.0.1:7890
# 留空则不使用代理
HTTP_PROXY=
HTTPS_PROXY=

# 前端文件目录（通常不需要修改）
# 本地开发（从 backend/cmd/api 运行）：FRONTEND_DIR=../../frontend
# Docker 部署（工作目录为 /app）：FRONTEND_DIR=./frontend（由 docker-compose 自动设置）
# FRONTEND_DIR=../frontend
