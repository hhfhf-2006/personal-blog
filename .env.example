# ============================================
# 个人博客 - 环境变量配置模板
# ============================================
# 使用方法：
#   1. 复制这个文件，重命名为 .env
#   2. 修改下面的值（如果默认值适合你，可以不改）
#   3. 后端启动时会自动读取这些变量
#
# 注意：.env 文件包含敏感信息（密码），
#       已被 .gitignore 忽略，不会上传到 GitHub。

# 后端服务端口
SERVER_PORT=8080

# PostgreSQL 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=blog
DB_PASSWORD=blog123456
DB_NAME=blog_db
DB_SSLMODE=disable
